"""
ExceptionLogger — structured writer for Data Contract Technical Validation
failures into the exceptions Delta table.

Inherits from BaseLogger for buffering, flushing, context-manager lifecycle,
and table-contract validation. Adds the exception-specific surface:
    * The exceptions Delta schema.
    * Registry lookup to resolve rule names → governance metadata.
    * ``log()``, ``log_many()``, and ``log_dataframe()`` public APIs.
    * The ``for_task()`` factory that wires everything together in one call.

Caller-facing surface (intentionally tiny):

    from utils.logger import ExceptionLogger

    with ExceptionLogger.for_task(
        spark=spark,
        collection_instance_id="2027-CAS-001",
        source_table="socpophousdata1_dev.social_census_parsed.individual",
        target_table="socpophousdata1_dev.social_census_validated.individual",
    ) as logger:
        logger.log(
            rule="invalid_date_format",
            event_type="DATACONTRACTVALIDATION",
            variable_name="date_of_birth",
            expected="yyyy-mm-dd",
            observed="32/13/2023",
            response_id="P123456789",
        )
"""

from __future__ import annotations

import json
import os
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable, Optional, Union

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    BooleanType,
    StringType,
    StructField,
    StructType,
    TimestampType,
)

from utils.logger.base_logger import BaseLogger
from utils.logger.context import build_run_context
from utils.logger.registry import (
    ErrorCodeRegistry,
    ResolvedCode,
    load_registry,
)
from utils.logger.violation import Violation


_LOG_TABLE_ENV_VAR = "CENSUS_EXCEPTION_LOG_TABLE"
_DEFAULT_LOG_TABLE = "socpophousdata1_dev.social_census_logs.exceptions"

_DEFAULT_BATCH_SIZE = 100


def _to_loggable(value: Any) -> Optional[str]:
    """
    Convert any caller-supplied value to a string suitable for the
    ``expected`` / ``observed`` columns.

    Convention (until/unless we move to VARIANT):
        * None        → None
        * primitives  → str(value)        e.g. 1899 → "1899", True → "True"
        * structures  → json.dumps(value) e.g. {"min": 0, "max": 120}

    This keeps simple cases queryable with ``WHERE observed = '1899'`` and
    structured cases queryable with ``WHERE parse_json(observed):min = 0``.
    Operators can rely on the convention because every record produced by
    every method goes through this function.
    """
    if value is None:
        return None
    if isinstance(value, (str, int, float, bool)):
        return str(value)
    # Lists, dicts, tuples, etc. — JSON-encode so they round-trip cleanly.
    return json.dumps(value, default=str)


class ExceptionLogger(BaseLogger):
    """
    Buffered writer for the ``social_census_logs.exceptions`` Delta table.

    Not thread-safe. One instance per task — construct via
    :meth:`ExceptionLogger.for_task`.
    """

    _SCHEMA: StructType = StructType([
        StructField("observation_id", StringType(), False),
        StructField("run_id", StringType(), False),
        StructField("job_id", StringType(), True),
        StructField("task_key", StringType(), False),
        StructField("source_table", StringType(), True),
        StructField("target_table", StringType(), True),
        StructField("validation_level", StringType(), False),
        StructField("event_type", StringType(), False),
        StructField("error_code", StringType(), False),
        StructField("severity", StringType(), False),
        StructField("message", StringType(), True),
        StructField("expected", StringType(), True),
        StructField("observed", StringType(), True),
        StructField("response_id", StringType(), True),
        StructField("collection_instance_id", StringType(), True),
        StructField("variable_name", StringType(), True),
        StructField("is_blocking", BooleanType(), False),
        StructField("stack_trace", StringType(), True),
        StructField("created_timestamp_utc", TimestampType(), False),
    ])

    @property
    def _schema(self) -> StructType:
        return self._SCHEMA

    # ────────────────────────────────────────────────────────
    # Constructor
    # ────────────────────────────────────────────────────────

    def __init__(
        self,
        spark: SparkSession,
        registry: ErrorCodeRegistry,
        context,
        table_path: str,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ):
        """
        Construct an ExceptionLogger.

        Most callers should use :meth:`for_task` instead — it wires up the
        registry, context, and default table path automatically.
        """
        super().__init__(
            spark=spark,
            context=context,
            table_path=table_path,
            batch_size=batch_size,
        )
        self._registry = registry

    # ────────────────────────────────────────────────────────
    # Factory
    # ────────────────────────────────────────────────────────

    @classmethod
    def for_task(
        cls,
        spark: SparkSession,
        *,
        collection_instance_id: str,
        task_key: Optional[str] = None,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        log_table_path: Optional[str] = None,
        registry_path: Optional[Union[str, Path]] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "ExceptionLogger":
        """
        Build a fully-configured ExceptionLogger for a single task.

        Collapses the multi-step setup into one call. The resulting logger
        is a context manager — use it inside a ``with`` block.
        """
        registry = load_registry(registry_path)

        context = build_run_context(
            collection_instance_id=collection_instance_id,
            task_key=task_key,
            source_table=source_table,
            target_table=target_table,
        )

        resolved_table = (
            log_table_path
            or os.environ.get(_LOG_TABLE_ENV_VAR)
            or _DEFAULT_LOG_TABLE
        )

        return cls(
            spark=spark,
            registry=registry,
            context=context,
            table_path=resolved_table,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Public API — single record
    # ────────────────────────────────────────────────────────

    def log(
        self,
        *,
        rule: str,
        event_type: str,
        variable_name: Optional[str] = None,
        expected: Any = None,
        observed: Any = None,
        response_id: Optional[str] = None,
        message: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Log one validation failure.

        Args:
            rule: Validation rule key (must exist in the registry).
            event_type: Event category — e.g. ``"DATACONTRACTVALIDATION"``,
                ``"coding"``, ``"MI_fix"``, ``"edit"``, ``"imputation"``.
            variable_name: Name of the offending variable, if applicable.
                None for FILE-level or RECORD-level failures.
            expected: Expected value / pattern / range. Stored as a string
                in the log table — primitives via ``str()``, structures via
                ``json.dumps()``.
            observed: Observed value, stored the same way as ``expected``.
            response_id: Primary key of the row, if applicable. ``None``
                for FILE-level failures.
            message: Custom human-readable message. If omitted, a default
                ``"Rule X failed. Expected=..., Observed=..."`` is generated.
            stack_trace: Traceback string for technical failures. Typically
                ``traceback.format_exc()`` inside an ``except`` block.
        """
        resolved = self._registry.resolve(rule)
        record = self._build_record(
            resolved=resolved,
            event_type=event_type,
            rule=rule,
            variable_name=variable_name,
            expected=expected,
            observed=observed,
            response_id=response_id,
            message=message,
            stack_trace=stack_trace,
            timestamp=datetime.now(timezone.utc),
        )
        self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — bulk for one logical record
    # ────────────────────────────────────────────────────────

    def log_many(
        self,
        violations: Iterable[Violation],
        *,
        event_type: str,
        response_id: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Log many violations that share a single response_id and event_type.

        Use when one logical record fails multiple validation rules — e.g.
        a record where ``person_nbr`` is null AND ``i_mode`` is invalid AND
        ``i_submitted_date_time`` is malformed. All three failures share
        the same ``response_id``.

        For failures that span many response_ids, use :meth:`log_dataframe`
        instead.

        Each Violation may carry its own ``message``. When ``Violation.message``
        is set, it is used as-is. When None, the logger generates a default
        ``"Rule X failed. Expected=..., Observed=..."`` message.

        Args:
            violations: Iterable of Violation instances.
            event_type: Event category shared by all violations.
            response_id: The response_id every violation relates to.
                ``None`` is valid for FILE-level batches that don't have
                a per-record identifier.
            stack_trace: Optional traceback shared across all violations.
        """
        violations = list(violations)

        # One timestamp per batch — every violation in this call shares it.
        timestamp = datetime.now(timezone.utc)

        for violation in violations:
            resolved = self._registry.resolve(violation.rule)
            record = self._build_record(
                resolved=resolved,
                event_type=event_type,
                rule=violation.rule,
                variable_name=violation.variable_name,
                expected=violation.expected,
                observed=violation.observed,
                response_id=response_id,
                message=violation.message,  # None ⇒ auto-generated in _build_record
                stack_trace=stack_trace,
                timestamp=timestamp,
            )
            self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — DataFrame-based bulk logging
    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        rule: str,
        event_type: str,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
        expected: Any = None,
        response_id_column: str,
        observed_column: str,
        message: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> int:
        """
        Log every row of a DataFrame as a separate exception record.

        Use when validation produced its results as a DataFrame — the
        natural output of ``.filter(...)`` or expectation checks — and
        you'd otherwise have to write ``df.collect()`` plus a Python loop.

        Per-row vs constant fields:
            Per-row (must be DataFrame columns):
                ``response_id_column``, ``observed_column``,
                and optionally ``variable_name_column``.
            Constant for the whole call:
                ``rule``, ``event_type``, ``expected``, ``message``,
                ``stack_trace``, and (constant) ``variable_name``.

        Variable-name shapes:
            * Pass ``variable_name="dob_year"`` when the whole DataFrame
              is one-variable-at-a-time validation. Every record has the
              same ``variable_name``.
            * Pass ``variable_name_column="variable"`` when the DataFrame
              spans multiple variables — each row says which variable
              failed in its own column.
            Pass exactly one of these. Passing both is a programming error.

        Args:
            df: PySpark DataFrame containing one row per failure.
            rule: Validation rule key (must exist in the registry).
            event_type: Event category — same for every row.
            variable_name: Constant variable name. Mutually exclusive with
                ``variable_name_column``.
            variable_name_column: DataFrame column holding the variable
                name (when validation spans multiple variables).
            expected: Constant expected value/pattern. Same for every row.
                Per-row expected values are not supported in this call —
                if you need them, split into multiple ``log_dataframe()``
                calls per (rule, expected) combination.
            response_id_column: DataFrame column holding response_id values.
                Required — DataFrame validation is row-scoped by definition.
            observed_column: DataFrame column holding the observed values.
                Required, same reasoning.
            message: Constant override for the human message.
            stack_trace: Constant stack trace.

        Returns:
            The number of records appended to the buffer.

        Raises:
            ValueError: if both ``variable_name`` and ``variable_name_column``
                are supplied, if a referenced column doesn't exist in
                ``df``, or if the DataFrame exceeds the safety size limit.

        Performance note:
            Calls ``df.count()`` then ``df.collect()`` — driver-side
            iteration. Safe for failure DataFrames up to ~100k rows; raises
            on larger inputs to protect driver memory. Filter your
            DataFrame to actual failures before passing it in.
        """
        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` (constant) or "
                "`variable_name_column` (per-row), not both."
            )

        for arg_name, col_name in [
            ("response_id_column", response_id_column),
            ("observed_column", observed_column),
            ("variable_name_column", variable_name_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} (passed as {arg_name}) not in "
                    f"DataFrame. Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)
        if row_count == 0:
            return 0

        # Resolve registry metadata once — same for every row.
        resolved = self._registry.resolve(rule)
        timestamp = datetime.now(timezone.utc)

        rows = df.collect()
        for row in rows:
            row_dict = row.asDict()
            record = self._build_record(
                resolved=resolved,
                event_type=event_type,
                rule=rule,
                variable_name=(
                    row_dict[variable_name_column]
                    if variable_name_column
                    else variable_name
                ),
                expected=expected,
                observed=row_dict[observed_column],
                response_id=row_dict[response_id_column],
                message=message,
                stack_trace=stack_trace,
                timestamp=timestamp,
            )
            self._add_to_buffer(record)

        return row_count

    # ────────────────────────────────────────────────────────
    # Internal — record assembly
    # ────────────────────────────────────────────────────────

    def _build_record(
        self,
        *,
        resolved: ResolvedCode,
        event_type: str,
        rule: str,
        variable_name: Optional[str],
        expected: Any,
        observed: Any,
        response_id: Optional[str],
        message: Optional[str],
        stack_trace: Optional[str],
        timestamp: datetime,
    ) -> dict:
        """
        Assemble one Delta-ready record dict. Pure function — no side effects.

        Auto-generates the human message when ``message`` is None.
        ``expected`` and ``observed`` go through ``_to_loggable`` so they
        land in the table as queryable strings.
        """
        if message is None:
            message = (
                f"Rule '{rule}' failed. "
                f"Expected={expected!r}, Observed={observed!r}"
            )

        return {
            **self._context_fields(),
            "observation_id": str(uuid.uuid4()),
            "validation_level": resolved.validation_level.value,
            "event_type": event_type,
            "error_code": resolved.error_code,
            "severity": resolved.severity.value,
            "message": message,
            "expected": _to_loggable(expected),
            "observed": _to_loggable(observed),
            "response_id": response_id,
            "variable_name": variable_name,
            "is_blocking": resolved.is_blocking,
            "stack_trace": stack_trace,
            "created_timestamp_utc": timestamp,
        }
