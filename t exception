def test_log_dataframe_field_column_per_row(logger: ExceptionLogger):
    """
    field_column lets each row declare which column failed. Useful when
    a single validation pass spans multiple fields.
    """
    df = FakeInputDataFrame(
        columns=["response_id", "field"],
        rows=[
            {"response_id": "P-001", "field": "dob_year"},
            {"response_id": "P-002", "field": "i_mode"},
        ],
    )

    logger.log_dataframe(
        df,
        rule="null_not_allowed",
        event_type="DATACONTRACTVALIDATION",
        response_id_column="response_id",
        field_column="field",
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    rows = spark.created[0].rows
    assert rows[0]["variable_name"] == "dob_year"
    assert rows[1]["variable_name"] == "i_mode"


def test_log_dataframe_rejects_field_and_field_column_both_set(
    logger: ExceptionLogger,
):
    """
    Pass either constant `field` or per-row `field_column`, never both —
    the conflict is a programming error.
    """
    df = FakeInputDataFrame(columns=["response_id"], rows=[{"response_id": "P-1"}])

    with pytest.raises(ValueError, match="not both"):
        logger.log_dataframe(
            df,
            rule="null_not_allowed",
            event_type="DC",
            field="dob_year",
            field_column="field",
            response_id_column="response_id",
        )


def test_log_dataframe_rejects_unknown_column(logger: ExceptionLogger):
    """
    Catch typos in column names early — silently producing all-NULL columns
    is worse than failing at submission.
    """
    df = FakeInputDataFrame(columns=["response_id"], rows=[{"response_id": "P-1"}])

    with pytest.raises(ValueError, match="not in DataFrame"):
        logger.log_dataframe(
            df,
            rule="null_not_allowed",
            event_type="DC",
            response_id_column="not_a_column",
        )


def test_log_dataframe_empty_input_is_noop(logger: ExceptionLogger):
    """An empty DataFrame should return 0 and not push anything to the buffer."""
    df = FakeInputDataFrame(columns=["response_id"], rows=[])

    written = logger.log_dataframe(
        df,
        rule="null_not_allowed",
        event_type="DC",
        response_id_column="response_id",
    )

    assert written == 0
    assert logger.buffer_size == 0


def test_log_dataframe_rejects_oversized_input(logger: ExceptionLogger):
    """
    The 100k-row safety limit protects driver memory. Tests use a much
    smaller fake limit so we don't have to materialise 100k rows in memory.
    """
    # Temporarily override the class-level limit for this test only.
    logger.DATAFRAME_ROW_LIMIT = 3
    df = FakeInputDataFrame(
        columns=["response_id"],
        rows=[{"response_id": f"P-{i}"} for i in range(5)],
    )

    with pytest.raises(ValueError, match="exceeding the safety limit"):
        logger.log_dataframe(
            df,
            rule="null_not_allowed",
            event_type="DC",
            response_id_column="response_id",
        )
