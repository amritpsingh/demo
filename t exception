def test_flush_empty_buffer_is_noop(logger: ExceptionLogger):
    logger.flush()  # must not raise, must not write
    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    assert spark.created == []


def test_flush_failure_preserves_buffer(registry_file: Path, run_context: RunContext):
    spark = _make_spark(raise_on_create=True)
    logger = ExceptionLogger(
        spark=spark,  # type: ignore[arg-type]
        registry=load_registry(registry_file),
        context=run_context,
        table_path="cat.logs.exceptions",
        batch_size=100,
    )

    logger.log(rule="null_not_allowed", event_type="DC")

    with pytest.raises(RuntimeError, match="Failed to write"):
        logger.flush()

    # Buffer must still contain the record — operator needs to see what failed.
    assert logger.buffer_size == 1


