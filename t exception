def test_log_dataframe_creates_one_record_per_row(logger: ExceptionLogger):
    """
    Two failing rows in the input DataFrame should produce two exception
    records, each carrying the per-row response_id and observed values
    plus the constant rule/event_type/expected applied to every row.
    """
    df = FakeInputDataFrame(
        columns=["response_id", "observed"],
        rows=[
            {"response_id": "P-001", "observed": 1899},
            {"response_id": "P-002", "observed": 2050},
        ],
    )

    written = logger.log_dataframe(
        df,
        rule="value_out_of_range",
        event_type="DATACONTRACTVALIDATION",
        field="dob_year",
        expected="1900-2026",
        response_id_column="response_id",
        observed_column="observed",
    )

    assert written == 2
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    rows = spark.created[0].rows

    assert len(rows) == 2
    assert rows[0]["response_id"] == "P-001"
    assert rows[0]["variable_name"] == "dob_year"
    assert "1899" in rows[0]["message"]
    assert rows[1]["response_id"] == "P-002"
    assert "2050" in rows[1]["message"]


def test_log_dataframe_resolves_governance_once(logger: ExceptionLogger):
    """
    The registry should be consulted once for the whole DataFrame, not
    once per row — every record carries the same error_code / severity /
    is_blocking values.
    """
    df = FakeInputDataFrame(
        columns=["response_id", "observed"],
        rows=[
            {"response_id": "P-001", "observed": "x"},
            {"response_id": "P-002", "observed": "y"},
        ],
    )

    logger.log_dataframe(
        df,
        rule="invalid_date_format",
        event_type="DATACONTRACTVALIDATION",
        response_id_column="response_id",
        observed_column="observed",
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    rows = spark.created[0].rows

    # Both rows resolved to the same FIELD-level governance.
    assert all(r["error_code"] == "INVALID_DATE_FORMAT" for r in rows)
    assert all(r["validation_level"] == "FIELD" for r in rows)
    assert all(r["is_blocking"] is True for r in rows)


