def test_log_many_with_scalar_response_id(logger: ExceptionLogger):
    """Common path — all violations share the same response_id."""
    violations = [
        Violation(rule="invalid_date_format", field="dob", expected="d", observed="x"),
        Violation(rule="null_not_allowed", field="name"),
    ]
    logger.log_many(
        violations, event_type="DATACONTRACTVALIDATION", response_id="P999"
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows

    assert [r["response_id"] for r in records] == ["P999", "P999"]


def test_log_many_with_aligned_response_id_list(logger: ExceptionLogger):
    violations = [
        Violation(rule="invalid_date_format"),
        Violation(rule="null_not_allowed"),
    ]
    logger.log_many(
        violations,
        event_type="DATACONTRACTVALIDATION",
        response_id=["A", "B"],
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows
    assert [r["response_id"] for r in records] == ["A", "B"]


def test_log_many_mismatched_response_id_list_rejected(logger: ExceptionLogger):
    violations = [Violation(rule="null_not_allowed"), Violation(rule="null_not_allowed")]
    with pytest.raises(ValueError, match="does not match violation count"):
        logger.log_many(
            violations, event_type="DC", response_id=["only_one"]
        )


def test_log_many_shares_single_timestamp(logger: ExceptionLogger):
    """All records from one log_many call must have identical timestamps."""
    violations = [Violation(rule="null_not_allowed") for _ in range(5)]
    logger.log_many(violations, event_type="DC")
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows
    timestamps = {r["created_timestamp_utc"] for r in records}
    assert len(timestamps) == 1, "all records in one batch should share a timestamp"


def test_auto_flush_on_batch_size(registry_file: Path, run_context: RunContext):
    spark = _make_spark()
    logger = ExceptionLogger(
        spark=spark,  # type: ignore[arg-type]
        registry=load_registry(registry_file),
        context=run_context,
        table_path="cat.logs.exceptions",
        batch_size=2,
    )

    logger.log(rule="null_not_allowed", event_type="DC")
    assert logger.buffer_size == 1
    assert spark.created == []

    logger.log(rule="null_not_allowed", event_type="DC")
    # Hit batch_size — should have auto-flushed. spark.created is now a
    # list of FakeDataFrame objects (shared helper format), and each df
    # carries its rows in .rows.
    assert logger.buffer_size == 0
    assert len(spark.created) == 1
    assert len(spark.created[0].rows) == 2


