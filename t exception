def test_context_manager_flushes_on_normal_exit(logger: ExceptionLogger):
    with logger as lg:
        lg.log(rule="null_not_allowed", event_type="DC")
        assert lg.buffer_size == 1

    assert logger.buffer_size == 0
    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    assert len(spark.created) == 1


def test_context_manager_flushes_on_exception_exit(logger: ExceptionLogger):
    """Pipeline raising shouldn't cause log loss."""
    with pytest.raises(RuntimeError, match="pipeline failure"):
        with logger as lg:
            lg.log(rule="null_not_allowed", event_type="DC")
            raise RuntimeError("pipeline failure")

    # Records buffered before the exception must still have been flushed.
    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    assert len(spark.created) == 1
    assert len(spark.created[0].rows) == 1


def test_context_manager_does_not_suppress_exception(logger: ExceptionLogger):
    """__exit__ returns False — original exception must propagate."""
    class MyErr(Exception):
        pass

    with pytest.raises(MyErr):
        with logger:
            raise MyErr("test")
