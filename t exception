def test_log_dataframe_rejects_variable_name_and_column_both_set(
    logger: ExceptionLogger,
):
    """
    Pass either constant variable_name or per-row variable_name_column,
    never both — the conflict is a programming error.
    """
    df = FakeInputDataFrame(
        columns=["response_id", "observed", "variable"],
        rows=[{"response_id": "P-1", "observed": "x", "variable": "v"}],
    )

    with pytest.raises(ValueError, match="not both"):
        logger.log_dataframe(
            df,
            rule="null_not_allowed",
            event_type="DC",
            variable_name="dob_year",
            variable_name_column="variable",
            response_id_column="response_id",
            observed_column="observed",
        )


