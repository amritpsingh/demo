        ("Online", "Online"),
        ("yyyy-mm-dd", "yyyy-mm-dd"),
    ],
)
def test_to_loggable_primitives_become_str(value, expected):
    """Primitives use str() so simple cases stay queryable with WHERE observed = 'X'."""
    assert _to_loggable(value) == expected


def test_to_loggable_dict_becomes_json():
    """Structured values get JSON-encoded so they round-trip via parse_json()."""
    import json
    result = _to_loggable({"min": 0, "max": 120})
    assert json.loads(result) == {"min": 0, "max": 120}


def test_to_loggable_list_becomes_json():
