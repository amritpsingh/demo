def test_log_assembles_expected_fields(logger: ExceptionLogger):
    logger.log(
        rule="invalid_date_format",
        event_type="DATACONTRACTVALIDATION",
        field="date_of_birth",
        expected="yyyy-mm-dd",
        observed="32/13/2023",
        response_id="P123",
    )

    assert logger.buffer_size == 1
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    # Governance fields come from the registry, not the caller.
    assert record["error_code"] == "INVALID_DATE_FORMAT"
    assert record["validation_level"] == "FIELD"
    assert record["severity"] == "ERROR"
    assert record["is_blocking"] is True

    # Caller fields are passed through untouched.
    assert record["event_type"] == "DATACONTRACTVALIDATION"
    assert record["variable_name"] == "date_of_birth"
    assert record["response_id"] == "P123"
    assert record["stack_trace"] is None

    # Context fields come from RunContext.
    assert record["run_id"] == "run-xyz"
    assert record["job_id"] == "job-abc"
    assert record["task_key"] == "test_task"
    assert record["collection_instance_id"] == "2027-TEST-001"

    # Auto-generated message quotes values for readability.
    assert "Rule 'invalid_date_format'" in record["message"]
    assert "'32/13/2023'" in record["message"]


def test_log_accepts_custom_message_and_stack_trace(logger: ExceptionLogger):
    logger.log(
        rule="null_not_allowed",
        event_type="DATACONTRACTVALIDATION",
        field="person_nbr",
        message="custom message",
        stack_trace="Traceback (most recent call last):\n  ...",
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    assert record["message"] == "custom message"
    assert record["stack_trace"].startswith("Traceback")


def test_log_unknown_rule_raises(logger: ExceptionLogger):
    with pytest.raises(KeyError, match="Unknown validation rule"):
        logger.log(rule="not_a_real_rule", event_type="TEST")


