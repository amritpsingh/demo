def _make_spark(
    raise_on_create: bool = False, raise_on_save: bool = False,
) -> FakeSpark:
    """
    A FakeSpark pre-registered with the exceptions table against
    ExceptionLogger's schema. Every logger-construction test needs this,
    because BaseLogger.__init__ now validates the table contract.
    """
    spark = FakeSpark(raise_on_create=raise_on_create, raise_on_save=raise_on_save)
    spark.catalog.register("cat.logs.exceptions", ExceptionLogger._SCHEMA)
    return spark


@pytest.fixture
