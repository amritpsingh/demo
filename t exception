def test_log_many_with_scalar_response_id(logger: ExceptionLogger):
    """Common path — all violations share the same response_id."""
    violations = [
        Violation(rule="invalid_date_format", field="dob", expected="d", observed="x"),
        Violation(rule="null_not_allowed", field="name"),
    ]
    logger.log_many(
        violations, event_type="DATACONTRACTVALIDATION", response_id="P999"
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows

    assert [r["response_id"] for r in records] == ["P999", "P999"]


