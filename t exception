def test_log_many_with_scalar_response_id(logger: ExceptionLogger):
    """Common path — all violations relate to the same response_id."""
    violations = [
        Violation(
            rule="invalid_date_format",
            variable_name="dob",
            expected="d",
            observed="x",
        ),
        Violation(rule="null_not_allowed", variable_name="name"),
    ]
    logger.log_many(
        violations,
        event_type="DATACONTRACTVALIDATION",
        response_id="P999",
    )
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows

    assert [r["response_id"] for r in records] == ["P999", "P999"]
    assert records[0]["variable_name"] == "dob"
    assert records[1]["variable_name"] == "name"


def test_log_many_shares_single_timestamp(logger: ExceptionLogger):
    """All records from one log_many call must have identical timestamps."""
    violations = [Violation(rule="null_not_allowed") for _ in range(5)]
    logger.log_many(violations, event_type="DC")
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows
    timestamps = {r["created_timestamp_utc"] for r in records}
    assert len(timestamps) == 1, "all records in one batch should share a timestamp"


def test_log_many_uses_violation_message_when_set(logger: ExceptionLogger):
    """When Violation.message is set, that message wins over auto-generation."""
    violations = [
        Violation(
            rule="null_not_allowed",
            variable_name="dob",
            message="custom-per-violation message",
        ),
        Violation(
            rule="null_not_allowed",
            variable_name="name",
            # message=None — should auto-generate
        ),
    ]
    logger.log_many(violations, event_type="DC", response_id="P-1")
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    records = spark.created[0].rows

    # First violation had a custom message — used as-is.
    assert records[0]["message"] == "custom-per-violation message"
    # Second violation had no message — auto-generated.
    assert records[1]["message"].startswith("Rule 'null_not_allowed' failed.")


def test_log_many_violation_expected_observed_persisted(logger: ExceptionLogger):
