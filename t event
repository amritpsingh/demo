"""
Unit tests for utils.logger.event_logger.

Uses shared test doubles from tests.unit._fakes so the fake Spark surface
stays in one place across all logger test files.

Focuses on EventLogger-specific behaviour — record assembly, optional
fields, message/variable_name shapes. Buffer, flush, and context-manager
semantics are inherited from BaseLogger and covered exhaustively in
tests/unit/test_base_logger.py, so we don't duplicate those here.
"""

from datetime import datetime, timezone

import pytest

from tests.unit._fakes import FakeInputDataFrame, FakeSpark
from utils.logger.context import RunContext
from utils.logger.event_logger import EventLogger


