def test_context_manager_flushes_on_clean_exit(run_context: RunContext):
    """
    End-to-end smoke test: using EventLogger as a context manager should
    auto-flush on exit. Full context-manager semantics (exceptions, flush
    failures, caller-exception priority) are covered in test_base_logger.py.
    """
    spark = _make_spark()

    with EventLogger(
        spark=spark,  # type: ignore[arg-type]
        context=run_context,
        table_path="cat.logs.events",
        batch_size=100,
    ) as logger:
        logger.log_event(event_type="coding", message="test")
        assert logger.buffer_size == 1

    # Exiting the with block triggered flush.
    assert len(spark.created) == 1
    assert len(spark.created[0].rows) == 1


