def test_context_manager_flushes_on_clean_exit(run_context: RunContext):
    spark = _make_spark()

    with EventLogger(
        spark=spark,  # type: ignore[arg-type]
        context=run_context,
        table_path="cat.logs.events",
        batch_size=100,
    ) as logger:
        logger.log(event_type="coding", message="test")
        assert logger.buffer_size == 1

    assert len(spark.created) == 1


