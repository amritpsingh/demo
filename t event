# log() — single record
# ─────────────────────────────────────────────

def test_log_assembles_expected_fields(logger: EventLogger):
    """
    A fully-specified log() call should produce a record with every
    caller-supplied field passed through, context fields stamped in, and
    framework-managed fields (observation_id, timestamp) populated.
    """
    logger.log(
        event_type="coding",
        message="Applied ethnic group coding rules successfully",
        rule_name="ethnic_group_coding_v1",
        response_id="P12345",
        variable_name="ethnic_group",
    )

    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    # Caller-supplied fields pass through.
    assert record["event_type"] == "coding"
    assert record["message"] == "Applied ethnic group coding rules successfully"
    assert record["rule_name"] == "ethnic_group_coding_v1"
    assert record["response_id"] == "P12345"
    assert record["variable_name"] == "ethnic_group"

    # Context fields stamped in from the RunContext.
    assert record["run_id"] == "run-xyz"
    assert record["job_id"] == "job-abc"
    assert record["task_key"] == "test_task"
    assert record["source_table"] == "cat.schema.src"
    assert record["target_table"] == "cat.schema.tgt"
    assert record["collection_instance_id"] == "2027-TEST-001"

    # Framework-managed fields populated automatically.
    assert record["observation_id"] is not None
    assert isinstance(record["created_timestamp_utc"], datetime)


def test_log_optional_fields_default_to_none(logger: EventLogger):
    """rule_name / response_id / variable_name are all optional."""
    logger.log(event_type="validation", message="passed")
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    assert record["rule_name"] is None
    assert record["response_id"] is None
    assert record["variable_name"] is None


def test_log_auto_generates_uuid_observation_id(logger: EventLogger):
    """observation_id is framework-managed — auto-generated UUID."""
    logger.log(event_type="coding", message="test")
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    import uuid as uuid_mod
    uuid_mod.UUID(record["observation_id"])  # raises if not a valid UUID


def test_log_auto_generates_utc_timestamp(logger: EventLogger):
    """Timestamp is framework-managed — datetime.now(timezone.utc)."""
    before = datetime.now(timezone.utc)
    logger.log(event_type="coding", message="test")
    after = datetime.now(timezone.utc)
    logger.flush()

    spark: FakeSpark = logger._spark  # type: ignore[assignment]
    [record] = spark.created[0].rows

    assert before <= record["created_timestamp_utc"] <= after
    assert record["created_timestamp_utc"].tzinfo == timezone.utc


def test_log_does_not_accept_observation_id_override(logger: EventLogger):
    """
    observation_id used to be overridable but the consolidation removed
    that — the framework owns this field.
    """
    with pytest.raises(TypeError, match="observation_id"):
        logger.log(  # type: ignore[call-arg]
            event_type="coding",
            message="test",
            observation_id="external-id",
        )


def test_log_does_not_accept_timestamp_override(logger: EventLogger):
    """
    created_timestamp_utc used to be overridable but the consolidation
    removed that — the framework owns this field.
    """
    with pytest.raises(TypeError, match="created_timestamp_utc"):
        logger.log(  # type: ignore[call-arg]
            event_type="coding",
            message="test",
            created_timestamp_utc=datetime(2025, 1, 1, tzinfo=timezone.utc),
        )


