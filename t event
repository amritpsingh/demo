def test_log_dataframe_requires_message_or_message_column(logger: EventLogger):
    """Every event needs a message — neither supplied is a programming error."""
    df = FakeInputDataFrame(
        columns=["response_id"], rows=[{"response_id": "P-1"}]
    )

    with pytest.raises(ValueError, match="every event needs a message"):
        logger.log_dataframe(
            df,
            event_type="coding",
            response_id_column="response_id",
        )


def test_log_dataframe_rejects_message_and_message_column_both_set(
    logger: EventLogger,
):
    """Both supplied is ambiguous — pick one."""
    df = FakeInputDataFrame(
        columns=["response_id", "msg"],
        rows=[{"response_id": "P-1", "msg": "foo"}],
    )

    with pytest.raises(ValueError, match="not both"):
        logger.log_dataframe(
            df,
            event_type="coding",
            message="constant",
            message_column="msg",
            response_id_column="response_id",
        )


def test_log_dataframe_rejects_variable_name_and_column_both_set(
