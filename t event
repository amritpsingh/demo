@pytest.fixture
def run_context() -> RunContext:
    return RunContext(
        run_id="run-xyz",
        job_id="job-abc",
        task_key="test_task",
        collection_instance_id="2027-TEST-001",
        source_table="cat.schema.src",
        target_table="cat.schema.tgt",
    )


def _make_spark(
    raise_on_create: bool = False, raise_on_save: bool = False,
) -> FakeSpark:
    """
    A FakeSpark pre-registered with the events table against EventLogger's
    schema. Every logger-construction test needs this because BaseLogger
    validates the table contract at __init__.
    """
    spark = FakeSpark(raise_on_create=raise_on_create, raise_on_save=raise_on_save)
    spark.catalog.register("cat.logs.events", EventLogger._SCHEMA)
    return spark


@pytest.fixture
def logger(run_context: RunContext) -> EventLogger:
    return EventLogger(
        spark=_make_spark(),  # type: ignore[arg-type]
        context=run_context,
        table_path="cat.logs.events",
        batch_size=100,
    )


