def test_auto_flush_on_batch_size(run_context: RunContext):
    spark = _make_spark()
    logger = EventLogger(
        spark=spark,  # type: ignore[arg-type]
        context=run_context,
        table_path="cat.logs.events",
        batch_size=2,
    )

    logger.log(event_type="coding", message="event 1")
    assert logger.buffer_size == 1
    assert spark.created == []

    logger.log(event_type="coding", message="event 2")

    assert logger.buffer_size == 0
    assert len(spark.created) == 1
    assert len(spark.created[0].rows) == 2


