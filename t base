def test_add_to_buffer_appends_record(run_context: RunContext):
    """Basic append — no auto-flush because we're under batch_size."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    logger._add_to_buffer({"observation_id": "a"})
    logger._add_to_buffer({"observation_id": "b"})

    assert logger.buffer_size == 2
    assert spark.created == []


def test_add_to_buffer_auto_flushes_at_batch_size(run_context: RunContext):
    """When the buffer reaches batch_size, the helper triggers an automatic flush."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=3,
    )

    logger._add_to_buffer({"observation_id": "a"})
    logger._add_to_buffer({"observation_id": "b"})
    assert logger.buffer_size == 2
    assert spark.created == []

    logger._add_to_buffer({"observation_id": "c"})

    assert logger.buffer_size == 0
    assert len(spark.created) == 1
    assert len(spark.created[0].rows) == 3


def test_context_fields_returns_all_six_context_columns(run_context: RunContext):
    """The method must return every context-derived field — and nothing else."""
    logger = ConcreteLogger(
        spark=_make_spark(), context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    fields = logger._context_fields()

    assert fields == {
        "run_id": "run-123",
        "job_id": "job-xyz",
        "task_key": "test_task",
        "source_table": None,
        "target_table": None,
        "collection_instance_id": "ci-1",
    }


def test_context_fields_returns_fresh_dict_each_call(run_context: RunContext):
    """
    Callers may mutate the returned dict. We must return a new dict every
    call so mutations don't leak into future log records.
    """
    logger = ConcreteLogger(
        spark=_make_spark(), context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    first = logger._context_fields()
    first["run_id"] = "mutated"

    second = logger._context_fields()
    assert second["run_id"] == "run-123"
    assert first is not second


def test_context_fields_includes_populated_source_and_target(run_context: RunContext):
    """When RunContext has source/target tables, those fields flow through."""
    populated_context = RunContext(
        run_id="run-123",
        job_id="job-xyz",
        task_key="test_task",
        collection_instance_id="ci-1",
        source_table="cat.schema.src",
        target_table="cat.schema.tgt",
    )
    logger = ConcreteLogger(
        spark=_make_spark(), context=populated_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    fields = logger._context_fields()
    assert fields["source_table"] == "cat.schema.src"
    assert fields["target_table"] == "cat.schema.tgt"
