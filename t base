def test_context_manager_returns_self(run_context: RunContext):
    """``with logger as lg`` must bind lg to the same object the caller passed in."""
    logger = ConcreteLogger(
        spark=_make_spark(), context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    with logger as lg:
        assert lg is logger


def test_context_manager_flushes_on_clean_exit(run_context: RunContext):
    """The main reason context managers exist — auto-flush on normal exit."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=100,
    )

    with logger as lg:
        lg._buffer.append({"observation_id": "a"})
        assert lg.buffer_size == 1

    assert logger.buffer_size == 0
    assert len(spark.created) == 1


def test_context_manager_flushes_on_exception_exit(run_context: RunContext):
    """
    Records buffered before an exception must still be written. This is
    the guarantee that makes ``with`` blocks safe — pipeline failure
    doesn't eat the diagnostic records explaining WHY it failed.
    """
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=100,
    )

    with pytest.raises(RuntimeError, match="pipeline failure"):
        with logger as lg:
            lg._buffer.append({"observation_id": "a"})
            raise RuntimeError("pipeline failure")

    assert len(spark.created) == 1
    assert spark.created[0].rows == [{"observation_id": "a"}]


def test_context_manager_does_not_suppress_caller_exception(
    run_context: RunContext,
):
    """Any exception from the ``with`` block must propagate unchanged."""
    logger = ConcreteLogger(
        spark=_make_spark(), context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    class BusinessLogicError(Exception):
        pass

    with pytest.raises(BusinessLogicError, match="specific message"):
        with logger:
            raise BusinessLogicError("specific message")


def test_context_manager_propagates_flush_failure_on_clean_exit(
    run_context: RunContext,
):
    """If the block exits cleanly but flush fails, the flush exception propagates."""
    spark = _make_spark(raise_on_create=True)
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    with pytest.raises(RuntimeError, match="Failed to write"):
        with logger as lg:
            lg._buffer.append({"observation_id": "a"})


def test_context_manager_prefers_caller_exception_over_flush_failure(
    run_context: RunContext, caplog
):
    """
    If both the block raises AND flush fails, the block's exception wins
    (it's the root cause). The flush failure is still logged to stdlib.

    ``caplog`` is a pytest built-in fixture that captures stdlib log
    messages so tests can assert on them.
    """
    spark = _make_spark(raise_on_create=True)
    logger = ConcreteLogger(
        spark=spark, context=run_context,
        table_path="cat.schema.tbl", batch_size=10,
    )

    class RootCauseError(Exception):
        pass

    with pytest.raises(RootCauseError):
        with logger as lg:
            lg._buffer.append({"observation_id": "a"})
            raise RootCauseError("this is the real problem")

    assert any(
        "Flush failed" in record.message for record in caplog.records
    )


