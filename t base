@pytest.mark.parametrize("bad_size", [0, -1, -100])
def test_non_positive_batch_size_rejected(run_context: RunContext, bad_size: int):
    """batch_size <= 0 is a programming error — surface it at construction."""
    with pytest.raises(ValueError, match="batch_size must be > 0"):
        ConcreteLogger(
            spark=_make_spark(),
            context=run_context,
            table_path="cat.schema.tbl",
            batch_size=bad_size,
        )


def test_constructor_stores_all_fields(run_context: RunContext):
    """Spot-check that every constructor argument lands on a private field."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark,
        context=run_context,
        table_path="cat.schema.tbl",
        batch_size=42,
    )

    assert logger._spark is spark
    assert logger._context is run_context
    assert logger._table_path == "cat.schema.tbl"
    assert logger._batch_size == 42
    assert logger._buffer == []


# ─────────────────────────────────────────────
# Table-contract validation
# ─────────────────────────────────────────────
#
# These tests exercise _validate_table_contract directly — they are the
# reason the constructor now touches the Spark catalog.

def test_missing_table_rejected(run_context: RunContext):
    """
    Construction must fail loudly when the target Delta table doesn't
    exist. Auto-creation is a migration concern, not a logger concern.
    """
    spark = FakeSpark()  # deliberately NOT calling _make_spark — nothing registered

    with pytest.raises(TableContractError, match="does not exist"):
        ConcreteLogger(
            spark=spark,
            context=run_context,
            table_path="cat.schema.missing_table",
            batch_size=10,
        )


def test_missing_column_rejected(run_context: RunContext):
    """
    If the target table is missing a column the logger writes, surface
    the specific column name in the error so operators know what to fix.
    """
    spark = FakeSpark()
    # Target table has no columns — the logger needs observation_id.
    spark.catalog.register("cat.schema.tbl", StructType([]))

    with pytest.raises(TableContractError, match="observation_id.*missing"):
        ConcreteLogger(
            spark=spark,
            context=run_context,
            table_path="cat.schema.tbl",
            batch_size=10,
        )


def test_type_mismatch_rejected(run_context: RunContext):
    """
    If the target table has the right column name but the wrong type,
    surface BOTH types in the error so operators can pick which is right.
    """
    spark = FakeSpark()
    # observation_id as an Integer — we expect String.
    spark.catalog.register(
        "cat.schema.tbl",
        StructType([StructField("observation_id", IntegerType(), False)]),
    )

    with pytest.raises(TableContractError) as exc_info:
        ConcreteLogger(
            spark=spark,
            context=run_context,
            table_path="cat.schema.tbl",
            batch_size=10,
        )

    message = str(exc_info.value)
    assert "observation_id" in message
    assert "string" in message  # logger's expected type
    assert "int" in message     # table's actual type


def test_extra_columns_in_target_allowed(run_context: RunContext):
    """
    The compatibility model is "logger's columns are a subset of target's
    columns." Extra columns in the target (e.g. added later by a migration)
    should NOT cause construction to fail — the appended rows simply leave
    those columns NULL, which is valid Delta behaviour.
    """
    spark = FakeSpark()
    spark.catalog.register(
        "cat.schema.tbl",
        StructType([
            StructField("observation_id", StringType(), False),
            StructField("future_column", StringType(), True),  # we don't know this
        ]),
    )

    # Should not raise.
    ConcreteLogger(
        spark=spark,
        context=run_context,
        table_path="cat.schema.tbl",
        batch_size=10,
    )


def test_contract_error_lists_all_mismatches(run_context: RunContext):
    """
    When multiple columns are wrong, report all of them in one error so
    operators can fix everything in one pass rather than iteratively.
    This is a kindness test — the feature still works if it only reports
    the first failure, but the UX is worse.
    """
    spark = FakeSpark()
    spark.catalog.register("cat.schema.tbl", StructType([]))

    # Define a subclass with two columns, both of which will be missing.
    class MultiColumnLogger(BaseLogger):
        _MULTI_SCHEMA = StructType([
            StructField("col_a", StringType(), False),
            StructField("col_b", StringType(), False),
        ])

        @property
        def _schema(self) -> StructType:
            return self._MULTI_SCHEMA

    with pytest.raises(TableContractError) as exc_info:
        MultiColumnLogger(
            spark=spark,
            context=run_context,
            table_path="cat.schema.tbl",
            batch_size=10,
        )

    message = str(exc_info.value)
    assert "col_a" in message
    assert "col_b" in message


