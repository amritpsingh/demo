def test_buffer_size_reflects_buffer(run_context: RunContext):
    """buffer_size is a read-only view of len(self._buffer)."""
    logger = ConcreteLogger(
        spark=_make_spark(),
        context=run_context,
        table_path="cat.schema.tbl",
        batch_size=10,
    )

    assert logger.buffer_size == 0

    logger._buffer.append({"observation_id": "a"})
    logger._buffer.append({"observation_id": "b"})

    assert logger.buffer_size == 2


def test_table_path_exposes_the_target(run_context: RunContext):
