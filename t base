"""
Unit tests for utils.logger.base_logger.

Test doubles defined at the top of the file:
    * FakeDataFrame / FakeSpark / FakeCatalog / FakeTable — stand in for
      the PySpark APIs the logger uses. Never talks to a real cluster.
    * ConcreteLogger — satisfies BaseLogger's abstract surface so we can
      instantiate something and exercise the base-class behaviour.

Almost every test uses the ``_make_spark`` helper to get a FakeSpark with
the test table already registered in the catalog. This is cleaner than a
pytest fixture for this file because some tests want to vary the failure
flags (``raise_on_create``, ``raise_on_save``) and helpers take kwargs
more naturally than fixtures do.
"""

import pytest
from pyspark.sql.types import IntegerType, StringType, StructField, StructType

from utils.logger.base_logger import BaseLogger, TableContractError
from utils.logger.context import RunContext


# ─────────────────────────────────────────────
# Test doubles
# ─────────────────────────────────────────────

class FakeDataFrame:
    """
    Stand-in for a PySpark DataFrame — records the write chain so tests
    can assert on it without actually writing to Delta.
    """
    def __init__(self, rows, schema, raise_on_save: bool = False):
        self.rows = rows
        self.schema = schema
        self.raise_on_save = raise_on_save
        self._mode = None
        self._format = None
        self.saved_to = None

    @property
    def write(self):
        # Return self so .mode().format().saveAsTable(...) can chain on
        # the DataFrame. Simplest fake that mimics the real API shape.
        return self

    def mode(self, mode: str) -> "FakeDataFrame":
        self._mode = mode
        return self

    def format(self, fmt: str) -> "FakeDataFrame":
        self._format = fmt
        return self

    def saveAsTable(self, table_path: str) -> None:  # noqa: N802 — mimics Spark API
        if self.raise_on_save:
            raise RuntimeError("simulated Spark write failure")
        self.saved_to = table_path


class FakeCatalog:
    """Stand-in for ``spark.catalog``. Remembers which tables exist."""

    def __init__(self):
        self._tables: dict[str, StructType] = {}

    def register(self, table_path: str, schema: StructType) -> None:
        """Simulate a table with this schema existing in the metastore."""
        self._tables[table_path] = schema

    def tableExists(self, table_path: str) -> bool:  # noqa: N802 — mimics Spark API
        return table_path in self._tables

    def schema_for(self, table_path: str) -> StructType:
        return self._tables[table_path]


class FakeTable:
    """Minimal stand-in for DataFrame returned by spark.table()."""
    def __init__(self, schema: StructType):
        self.schema = schema


class FakeSpark:
    """
    Stand-in SparkSession. Carries a FakeCatalog so the logger's
    table-contract validation can run without Databricks, and records
    every DataFrame created so tests can inspect writes.
    """
    def __init__(self, raise_on_create: bool = False, raise_on_save: bool = False):
        self.raise_on_create = raise_on_create
        self.raise_on_save = raise_on_save
        self.created: list[FakeDataFrame] = []
        self.catalog = FakeCatalog()

    def createDataFrame(self, rows, schema):  # noqa: N802 — mimics Spark API
        if self.raise_on_create:
            raise RuntimeError("simulated createDataFrame failure")
        df = FakeDataFrame(list(rows), schema, raise_on_save=self.raise_on_save)
        self.created.append(df)
        return df

    def table(self, table_path: str) -> FakeTable:
        return FakeTable(self.catalog.schema_for(table_path))


class ConcreteLogger(BaseLogger):
    """
    Minimal concrete subclass that satisfies BaseLogger's abstract surface.
    Only purpose: exercise BaseLogger without pulling in the full
    ExceptionLogger / EventLogger machinery.
    """

    _TEST_SCHEMA = StructType([
        StructField("observation_id", StringType(), False),
    ])

    @property
    def _schema(self) -> StructType:
        return self._TEST_SCHEMA


# ─────────────────────────────────────────────
# Test helpers
# ─────────────────────────────────────────────

def _make_spark(
    raise_on_create: bool = False,
    raise_on_save: bool = False,
) -> FakeSpark:
    """
    Return a FakeSpark with the test table paths pre-registered against
    ConcreteLogger's schema. This is what most tests want — a "healthy"
    spark session where the target table exists and has a matching schema.

    Tests that want to simulate a *missing* table should use ``FakeSpark()``
    directly (no registration).
    """
    spark = FakeSpark(raise_on_create=raise_on_create, raise_on_save=raise_on_save)
    spark.catalog.register("cat.schema.tbl", ConcreteLogger._TEST_SCHEMA)
    spark.catalog.register("cat.schema.exceptions", ConcreteLogger._TEST_SCHEMA)
    return spark


