def test_flush_empty_buffer_is_noop(run_context: RunContext):
    """Flushing nothing must not raise and must not write — valid graceful shutdown."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context, table_path="cat.schema.tbl", batch_size=10,
    )

    logger.flush()

    assert spark.created == []


def test_flush_writes_buffered_records(run_context: RunContext):
    """Happy path — records accumulate, flush writes them, buffer clears."""
    spark = _make_spark()
    logger = ConcreteLogger(
        spark=spark, context=run_context, table_path="cat.schema.tbl", batch_size=100,
    )

    logger._buffer.append({"observation_id": "a"})
    logger._buffer.append({"observation_id": "b"})

    logger.flush()

    assert len(spark.created) == 1
    df = spark.created[0]
    assert df.rows == [{"observation_id": "a"}, {"observation_id": "b"}]
    assert df._mode == "append"
    assert df._format == "delta"
    assert df.saved_to == "cat.schema.tbl"
    assert logger.buffer_size == 0


def test_flush_preserves_buffer_on_createDataFrame_failure(run_context: RunContext):
    """
    If the write fails, the buffer must stay populated so the caller
    can retry or at least see what wasn't written. Opposite of the bug
    in the original EventLogger, which cleared the buffer before the write.
    """
    spark = _make_spark(raise_on_create=True)
    logger = ConcreteLogger(
        spark=spark, context=run_context, table_path="cat.schema.tbl", batch_size=10,
    )

    logger._buffer.append({"observation_id": "a"})

    with pytest.raises(RuntimeError, match="Failed to write 1 log record"):
        logger.flush()

    assert logger.buffer_size == 1


def test_flush_preserves_buffer_on_save_failure(run_context: RunContext):
    """Same property as above, but for failures during the .saveAsTable call."""
    spark = _make_spark(raise_on_save=True)
    logger = ConcreteLogger(
        spark=spark, context=run_context, table_path="cat.schema.tbl", batch_size=10,
    )

    logger._buffer.append({"observation_id": "a"})

    with pytest.raises(RuntimeError, match="Failed to write"):
        logger.flush()

    assert logger.buffer_size == 1


def test_flush_chains_original_exception(run_context: RunContext):
    """
    The RuntimeError must carry the original exception as __cause__.
    Without chaining, operators lose the underlying reason the write failed.
    """
    spark = _make_spark(raise_on_create=True)
    logger = ConcreteLogger(
        spark=spark, context=run_context, table_path="cat.schema.tbl", batch_size=10,
    )
    logger._buffer.append({"observation_id": "a"})

    with pytest.raises(RuntimeError) as exc_info:
        logger.flush()

    assert isinstance(exc_info.value.__cause__, RuntimeError)
    assert "simulated createDataFrame failure" in str(exc_info.value.__cause__)


