"""
EventLogger — structured writer for observation events into the events
Delta table.

Writes non-fatal, informational events during processing (coding, MI_fix,
edit, imputation, validation). Unlike ExceptionLogger, there's no registry
— event_type and rule_name are free-text strings provided by the caller.

Inherits from BaseLogger for buffering, flushing, context-manager lifecycle,
and table-contract validation.

Caller-facing surface (intentionally tiny):

    from utils.logger import EventLogger

    with EventLogger.for_task(
        spark=spark,
        collection_instance_id="2027-CAS-001",
        source_table="socpophousdata1_dev.social_census_parsed.individual",
        target_table="socpophousdata1_dev.social_census_classified.individual",
    ) as logger:
        logger.log(
            event_type="coding",
            message="Applied ethnic group coding rules successfully",
            rule_name="ethnic_group_coding_v1",
            response_id="P12345",
            variable_name="ethnic_group",
        )
"""

from __future__ import annotations

import os
import uuid
from datetime import datetime, timezone
from typing import Optional

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    StringType,
    StructField,
    StructType,
    TimestampType,
)

from utils.logger.base_logger import BaseLogger
from utils.logger.context import RunContext, build_run_context


_LOG_TABLE_ENV_VAR = "CENSUS_EVENT_LOG_TABLE"
_DEFAULT_LOG_TABLE = "socpophousdata1_dev.social_census_logs.events"

_DEFAULT_BATCH_SIZE = 1000


class EventLogger(BaseLogger):
    """
    Buffered writer for the ``social_census_logs.events`` Delta table.

    Not thread-safe. One instance per task — construct via
    :meth:`EventLogger.for_task`.
    """

    _SCHEMA: StructType = StructType([
        StructField("observation_id", StringType(), False),
        StructField("run_id", StringType(), False),
        StructField("job_id", StringType(), True),
        StructField("task_key", StringType(), False),
        StructField("source_table", StringType(), True),
        StructField("target_table", StringType(), True),
        StructField("event_type", StringType(), False),
        StructField("rule_name", StringType(), True),
        StructField("message", StringType(), True),
        StructField("response_id", StringType(), True),
        StructField("collection_instance_id", StringType(), True),
        StructField("variable_name", StringType(), True),
        StructField("created_timestamp_utc", TimestampType(), False),
    ])

    @property
    def _schema(self) -> StructType:
        return self._SCHEMA

    # ────────────────────────────────────────────────────────
    # Constructor
    # ────────────────────────────────────────────────────────

    def __init__(
        self,
        spark: SparkSession,
        context: RunContext,
        table_path: str,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ):
        """
        Construct an EventLogger.

        Most callers should use :meth:`for_task` instead — it wires up
        the context and default table path automatically.
        """
        super().__init__(
            spark=spark,
            context=context,
            table_path=table_path,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Factory
    # ────────────────────────────────────────────────────────

    @classmethod
    def for_task(
        cls,
        spark: SparkSession,
        *,
        collection_instance_id: str,
        task_key: Optional[str] = None,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        log_table_path: Optional[str] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "EventLogger":
        """
        Build a fully-configured EventLogger for a single task.

        Mirrors :meth:`ExceptionLogger.for_task`. The resulting logger is
        a context manager — use it inside a ``with`` block.
        """
        context = build_run_context(
            collection_instance_id=collection_instance_id,
            task_key=task_key,
            source_table=source_table,
            target_table=target_table,
        )

        resolved_table = (
            log_table_path
            or os.environ.get(_LOG_TABLE_ENV_VAR)
            or _DEFAULT_LOG_TABLE
        )

        return cls(
            spark=spark,
            context=context,
            table_path=resolved_table,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Public API — single record
    # ────────────────────────────────────────────────────────

    def log(
        self,
        *,
        event_type: str,
        message: str,
        rule_name: Optional[str] = None,
        response_id: Optional[str] = None,
        variable_name: Optional[str] = None,
    ) -> None:
        """
        Log one observation event.

        Args:
            event_type: Event category — e.g. ``"coding"``, ``"MI_fix"``,
                ``"edit"``, ``"imputation"``, ``"validation"``.
            message: Human-readable description of the event.
            rule_name: Specific business rule name for the event.
                Free text (unlike ExceptionLogger's ``rule`` which must
                exist in the registry).
            response_id: Primary key of the row being observed, if any.
            variable_name: The name of the variable being processed.
        """
        record = self._build_record(
            event_type=event_type,
            message=message,
            rule_name=rule_name,
            response_id=response_id,
            variable_name=variable_name,
            timestamp=datetime.now(timezone.utc),
        )
        self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — DataFrame-based bulk logging
    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        event_type: str,
        rule_name: Optional[str] = None,
        message: Optional[str] = None,
        message_column: Optional[str] = None,
        response_id_column: str,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
    ) -> int:
        """
        Log every row of a DataFrame as a separate event record.

        Mirrors :meth:`ExceptionLogger.log_dataframe`. Use when an upstream
        step produced a DataFrame of events to record (e.g. an imputation
        step that wants to log one event per row imputed).

        Per-row vs constant fields:
            Per-row (DataFrame columns):
                ``response_id_column`` (required), and optionally
                ``message_column`` and ``variable_name_column``.
            Constant for the whole call:
                ``event_type``, ``rule_name``, and (constant)
                ``message`` and ``variable_name``.

        Message shape:
            * Pass ``message="constant text"`` when every row represents
              the same event message.
            * Pass ``message_column="msg"`` when each row has its own
              message text in a DataFrame column.
            Pass exactly one of these.

        Variable-name shape:
            * Pass ``variable_name="dob_year"`` when every row relates to
              the same variable.
            * Pass ``variable_name_column="variable"`` when rows span
              multiple variables.
            * Pass neither when the events aren't variable-scoped.

        Args:
            df: PySpark DataFrame, one row per event.
            event_type: Event category, applied to every row.
            rule_name: Constant rule_name applied to every row.
            message: Constant message text. Mutually exclusive with
                ``message_column``.
            message_column: DataFrame column holding the message text.
            response_id_column: DataFrame column holding response_id values.
                Required — bulk events are row-scoped.
            variable_name: Constant variable name. Mutually exclusive with
                ``variable_name_column``.
            variable_name_column: DataFrame column holding the variable name.

        Returns:
            Number of records appended to the buffer.

        Raises:
            ValueError: if neither ``message`` nor ``message_column`` is
                supplied, if both are supplied, if both ``variable_name``
                and ``variable_name_column`` are supplied, if a referenced
                column is missing, or if the DataFrame exceeds the safety
                size limit.

        Performance note:
            Driver-side iteration via ``.collect()``. Safe for up to
            ~100k rows. For larger inputs, filter or split first.
        """
        if message is None and message_column is None:
            raise ValueError(
                "Either `message` (constant) or `message_column` (per-row) "
                "must be supplied — every event needs a message."
            )
        if message is not None and message_column is not None:
            raise ValueError(
                "Pass either `message` (constant) or `message_column` "
                "(per-row), not both."
            )
        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` (constant) or "
                "`variable_name_column` (per-row), not both."
            )

        for arg_name, col_name in [
            ("message_column", message_column),
            ("response_id_column", response_id_column),
            ("variable_name_column", variable_name_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} (passed as {arg_name}) not in "
                    f"DataFrame. Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)
        if row_count == 0:
            return 0

        timestamp = datetime.now(timezone.utc)

        rows = df.collect()
        for row in rows:
            row_dict = row.asDict()
            record = self._build_record(
                event_type=event_type,
                message=(
                    row_dict[message_column] if message_column else message
                ),
                rule_name=rule_name,
                response_id=row_dict[response_id_column],
                variable_name=(
                    row_dict[variable_name_column]
                    if variable_name_column
                    else variable_name
                ),
                timestamp=timestamp,
            )
            self._add_to_buffer(record)

        return row_count

    # ────────────────────────────────────────────────────────
    # Internal — record assembly
    # ────────────────────────────────────────────────────────

    def _build_record(
        self,
        *,
        event_type: str,
        message: str,
        rule_name: Optional[str],
        response_id: Optional[str],
        variable_name: Optional[str],
        timestamp: datetime,
    ) -> dict:
        """
        Assemble one Delta-ready record dict. Pure function — no side effects.

        observation_id and timestamp are framework-managed — both
        auto-generated, never accepted from public callers.
        """
        return {
            **self._context_fields(),
            "observation_id": str(uuid.uuid4()),
            "event_type": event_type,
            "rule_name": rule_name,
            "message": message,
            "response_id": response_id,
            "variable_name": variable_name,
            "created_timestamp_utc": timestamp,
        }
